{
  "package": "buildinfo",
  "import_path": "github.com/platformcontext/platform-context-graph/go/internal/buildinfo",
  "directory": "go/internal/buildinfo",
  "source_files": ["doc.go", "buildinfo.go"],
  "exports": {
    "vars": [
      {"name": "Version", "type": "string", "default": "dev", "file": "buildinfo.go", "line": 6}
    ],
    "functions": [
      {"name": "AppVersion", "signature": "func AppVersion() string", "doc": "returns normalized application version; collapses empty/whitespace to dev", "file": "buildinfo.go", "line": 10}
    ]
  },
  "dependencies": {
    "internal": [],
    "stdlib": ["strings"]
  },
  "callers": [
    "go/internal/status/status.go",
    "go/internal/status/json.go",
    "go/internal/runtime/metrics.go",
    "go/internal/mcp/server.go",
    "go/internal/query/openapi.go",
    "go/internal/query/status.go",
    "go/cmd/pcg/root.go",
    "go/cmd/pcg/local_host.go",
    "go/cmd/pcg/graph_install_release_manifest.go"
  ],
  "ldflags_injection": "-ldflags \"-X github.com/platformcontext/platform-context-graph/go/internal/buildinfo.Version=<value>\"",
  "telemetry": "none directly; callers embed AppVersion in logs, metrics labels, and status payloads",
  "key_invariants": [
    "Version must only ever be written via -ldflags; no code should reassign it",
    "Empty or whitespace-only ldflags value collapses to dev",
    "dev means non-release source build in operator dashboards"
  ]
}
