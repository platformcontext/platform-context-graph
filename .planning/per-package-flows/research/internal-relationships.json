    {"name": "DiscoverEvidence", "file": "evidence.go", "line": 18, "role": "scan envelopes for IaC evidence, return EvidenceFact slice"},
    {"name": "Resolve", "file": "resolver.go", "line": 62, "role": "group evidence into candidates, apply assertions, promote to ResolvedRelationship"},
    {"name": "RegisterSchemaDrivenTerraformExtractors", "file": "terraform_schema.go", "line": 49, "role": "bootstrap schema-driven Terraform resource extractors from a schema dir"}
  ]
