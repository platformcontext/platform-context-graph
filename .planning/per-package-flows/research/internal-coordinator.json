  "deployment_modes": {
    "dark": "runs only runReconcile on reconcile ticker; reap and run-reconcile loops are OFF",
    "active": "runs runReconcile + runWorkflowReconciliation on reconcile ticker; runs runReapExpiredClaims on reap ticker"
  },
  "service_run_flow": {
    "initial_calls": [
      "runReconcile (always)",
      "runReapExpiredClaims (active only)",
      "runWorkflowReconciliation (active only)"
