    "refresh.go",
    "doc.go"
  ],
  "purpose": "Owns PCG's OpenTelemetry contract: metric instruments (Instruments struct), span names (Span* constants), structured log keys (LogKey* constants), phase constants (Phase*), attribute helpers (Attr*), the Bootstrap config type, OTEL provider initialization (Providers, NewProviders), and the TraceHandler slog wrapper. Every runtime-affecting package consumes this package; nothing imports it back.",
  "exported_types": [
    "Bootstrap",
    "Instruments",
    "Providers",
    "ProviderOption",
    "QueueObserver",
    "WorkerObserver",
    "AcceptanceObserver",
    "TraceHandler"
  ],
  "exported_functions": [
    "NewBootstrap(serviceName string) (Bootstrap, error)",
    "NewInstruments(meter metric.Meter) (*Instruments, error)",
    "RegisterObservableGauges(inst *Instruments, meter metric.Meter, queueObs QueueObserver, workerObs WorkerObserver) error",
    "RegisterAcceptanceObservableGauges(inst *Instruments, meter metric.Meter, acceptanceObs AcceptanceObserver) error",
    "RecordGOMEMLIMIT(meter metric.Meter, limitBytes int64) error",
    "NewProviders(ctx context.Context, b Bootstrap, opts ...ProviderOption) (*Providers, error)",
    "NewLogger(b Bootstrap, component, runtimeRole string) *slog.Logger",
    "NewLoggerWithWriter(b Bootstrap, component, runtimeRole string, writer io.Writer) *slog.Logger",
    "ScopeAttrs(scopeID, generationID, sourceSystem string) []slog.Attr",
    "DomainAttrs(domain, partitionKey string) []slog.Attr",
    "AcceptanceAttrs(scopeID, unitID, sourceRunID, generationID string) []slog.Attr",
    "PhaseAttr(phase string) slog.Attr",
    "FailureClassAttr(class string) slog.Attr",
    "AcceptanceStaleCountAttr(count int) slog.Attr",
    "EventAttr(name string) slog.Attr",
    "MetricDimensionKeys() []string",
    "SpanNames() []string",
    "LogKeys() []string",
    "RecordSkippedRefresh() uint64",
    "SkippedRefreshCount() uint64",
    "ResetSkippedRefreshCountForTesting()",
    "AttrScopeID(v string) attribute.KeyValue",
    "AttrScopeKind(v string) attribute.KeyValue",
    "AttrSourceSystem(v string) attribute.KeyValue",
    "AttrGenerationID(v string) attribute.KeyValue",
    "AttrCollectorKind(v string) attribute.KeyValue",
    "AttrDomain(v string) attribute.KeyValue",
    "AttrPartitionKey(v string) attribute.KeyValue",
    "AttrRunner(v string) attribute.KeyValue",
    "AttrLookupResult(v string) attribute.KeyValue",
    "AttrErrorType(v string) attribute.KeyValue",
    "AttrRepoSizeTier(v string) attribute.KeyValue",
    "AttrSkipReason(v string) attribute.KeyValue",
    "AttrNodeType(v string) attribute.KeyValue",
    "AttrEdgeType(v string) attribute.KeyValue",
    "AttrWritePhase(v string) attribute.KeyValue",
    "AttrOutcome(v string) attribute.KeyValue"
