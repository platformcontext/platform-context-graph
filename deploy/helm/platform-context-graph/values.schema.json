{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "LoadBalancer", "NodePort"]
        },
        "port": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "repoSync": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "bootstrap": { "type": "boolean" },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "intervalSeconds": { "type": "integer", "minimum": 1 },
        "auth": {
          "type": "object",
          "properties": {
            "method": {
              "type": "string",
              "enum": ["githubApp", "token", "ssh", "none"]
            }
          }
        },
        "source": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["githubOrg", "explicit", "filesystem"]
            },
            "repositories": {
              "type": "array",
              "items": { "type": "string" }
            },
            "rules": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["exact", "regex"]
                  },
                  "value": { "type": "string" }
                },
                "required": ["type", "value"],
                "additionalProperties": false
              }
            }
          }
        }
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "environment": { "type": "string" },
        "otel": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "endpoint": { "type": "string" },
            "protocol": {
              "type": "string",
              "enum": ["grpc", "http/protobuf"]
            },
            "insecure": { "type": "boolean" },
            "headers": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "tracesExporter": { "type": "string" },
            "metricsExporter": { "type": "string" },
            "logsExporter": { "type": "string" },
            "resourceAttributes": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "excludedUrls": {
              "type": "array",
              "items": { "type": "string" }
            },
            "metricExportIntervalSeconds": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "contentStore": {
      "type": "object",
      "properties": {
        "dsn": { "type": "string" }
      }
    },
    "exposure": {
      "type": "object",
      "properties": {
        "ingress": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "gateway": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    }
  }
}
