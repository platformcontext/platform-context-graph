.env
.envrc
.venv
env/
venv/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo

# mkdocs documentation
/site
docs/site/

# Cursor
.cursorignore
.cursorindexingignore

# Repo-local tooling and scratch files. .claude/* (not .claude/) so git still
# descends into the directory and the negations below can re-include the
# project-level hook, settings, and skill shipped with the repo.
.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/hooks/**
!.claude/skills/
!.claude/skills/**
.worktrees/
.mcp.json
.vercel/
mcp.json
*.bak
*.temp
*.tmp
*.log
playground/
todo.md
.pcg-compose-runs/

# macOS system files
.DS_Store
.omc/
.serena/
.superpowers/

# Doc-keeper drift state (regenerated by hook on each tool use)
.pcg-doc-state/

# Per-package flow research artifacts. Agents write these as scratch when
# building docs; the JSON is intermediate state, not part of the doc contract.
# scripts/verify-doc-claims.sh is the gate that the docs themselves stay
# source-grounded, so committing the scratch is just noise.
.planning/per-package-flows/

# Claude Code per-user overrides; .claude/settings.json is committed so the
# project hook works for everyone who clones.
.claude/settings.local.json
