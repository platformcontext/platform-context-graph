# PlatformContextGraph local compose secrets and overrides

# Local database passwords used by docker-compose.yaml and docker-compose.template.yml.
# Replace these before exposing the stack outside a trusted development environment.
PCG_NEO4J_PASSWORD=change-me
PCG_POSTGRES_PASSWORD=change-me

# Optional explicit API/MCP bearer token for the HTTP service.
# Local compose can auto-generate and persist one when this is omitted.
PCG_API_KEY=

# Optional docs hardening flag. Set to false to disable /api/v0/openapi.json,
# /api/v0/docs, and /api/v0/redoc entirely.
PCG_ENABLE_PUBLIC_DOCS=true

# Optional local service port overrides.
PCG_HTTP_PORT=8080
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
JAEGER_UI_PORT=16686
OTEL_COLLECTOR_OTLP_GRPC_PORT=4317
OTEL_COLLECTOR_OTLP_HTTP_PORT=4318
OTEL_COLLECTOR_PROMETHEUS_PORT=9464

# Optional local indexing inputs and worker tuning.
PCG_FILESYSTEM_HOST_ROOT=./tests/fixtures/ecosystems
PCG_PARSE_WORKERS=4
PCG_INDEX_QUEUE_DEPTH=8
PCG_REPO_SYNC_INITIAL_DELAY_SECONDS=30
REPO_SYNC_INTERVAL_SECONDS=900
